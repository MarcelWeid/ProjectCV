# ProjectCV — Environment configuration template
# Copy this file to .env (which is gitignored) and fill in the values.
# Never commit the .env file.

# ===== Database =====
# Hetzner Managed Postgres connection string
# Format: Host=...;Port=5432;Database=projectcv;Username=...;Password=...;SslMode=Require
PROJECTCV__DATABASE__CONNECTIONSTRING=

# ===== Azure OpenAI =====
PROJECTCV__AZUREOPENAI__ENDPOINT=https://your-resource.openai.azure.com/
PROJECTCV__AZUREOPENAI__APIKEY=
PROJECTCV__AZUREOPENAI__CHATDEPLOYMENT=gpt-4o
PROJECTCV__AZUREOPENAI__EMBEDDINGDEPLOYMENT=text-embedding-3-large
PROJECTCV__AZUREOPENAI__APIVERSION=2024-10-21

# ===== Security =====
# HMAC secret used to hash company tokens before storing in DB.
# Generate with: openssl rand -base64 32
PROJECTCV__SECURITY__TOKENHMACSECRET=

# Bearer token for /admin/kill and /admin/revive endpoints.
# Generate with: openssl rand -base64 32
PROJECTCV__SECURITY__ADMINBEARERTOKEN=

# ===== Budget guard =====
PROJECTCV__BUDGET__DAILYCAPEUR=5.00
PROJECTCV__BUDGET__MONTHLYCAPEUR=50.00

# ===== Logging =====
# Set to true ONLY when debugging — logs full message content (SR-031).
# Must remain false in production.
PROJECTCV__LOGGING__VERBOSE=false

# ===== Alerts =====
# Email or webhook for budget / health alerts (OR-003). To be defined.
PROJECTCV__ALERTS__EMAIL=
